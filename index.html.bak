<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
<title>Dr. A. Kula and the Pig & Swine Crisis</title>
<meta name="description" content="Pig & Swine: Aplikant in Warsaw - a legal RPG game" />
<meta name="theme-color" content="#1b1f31" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Pig & Swine" />
  <style>
  :root {
    --ink:#1b1f31; --paper:#f5ead2; --gold:#d7a84f; --red:#aa3d42; --green:#526f45;
  }
  html, body { margin:0; height:100%; background:#161827; font-family: system-ui, Segoe UI, sans-serif; color:var(--paper); overflow:hidden; }
  #wrap { display:grid; place-items:center; height:100%; background: radial-gradient(circle at 50% 20%, #2a2f4a, #131522 65%); }
  canvas { image-rendering: pixelated; border: 6px solid #0b0d16; box-shadow: 0 25px 70px #0009; background:#27334a; max-width: min(96vw, 1200px); max-height: 82vh; }
  #panel { width:min(96vw, 1200px); display:flex; gap:14px; justify-content:space-between; align-items:center; margin-top:10px; color:#f8efd8; font-size:14px; }
  kbd { background:#0b0d16; border:1px solid #59617f; border-radius:5px; padding:2px 7px; box-shadow: inset 0 -2px #0008; }
  #hint { opacity:.88; }
  a { color:#ffd76c; }

  /* Touch Controls */
  #touch-controls { display:none; position:fixed; bottom:20px; left:0; right:0; z-index:1000; pointer-events:none; }
  #dpad { position:absolute; left:20px; bottom:0; width:150px; height:150px; }
  #dpad button { position:absolute; width:50px; height:50px; background:rgba(11,13,22,.75); border:2px solid #d7a84f; color:#f5ead2; font-size:24px; border-radius:8px; pointer-events:auto; cursor:pointer; user-select:none; -webkit-user-select:none; }
  #dpad .up { top:0; left:50px; }
  #dpad .down { bottom:0; left:50px; }
  #dpad .left { top:50px; left:0; }
  #dpad .right { top:50px; right:0; }
  #action-buttons { position:absolute; right:20px; bottom:0; display:flex; gap:10px; }
  #action-buttons button { width:60px; height:60px; background:rgba(170,61,66,.75); border:2px solid #ffd76c; color:#f5ead2; font-size:14px; font-weight:bold; border-radius:10px; pointer-events:auto; cursor:pointer; user-select:none; -webkit-user-select:none; }
  #action-buttons button.qbtn { background:rgba(215,168,79,.75); border-color:#1b1f31; }
  #action-buttons button.ibtn { background:rgba(82,111,69,.75); border-color:#d7a84f; }
  @media (hover:none) and (pointer:coarse) {
    #touch-controls { display:block; }
    #panel { display:none; }
  }
  </style>
</head>
<body>
<div id="wrap">
  <div>
    <canvas id="game" width="960" height="640"></canvas>
    <div id="panel">
      <div><strong>Dr. A. Kula</strong> — Pig & Swine, Polish law, courts, and human rights</div>
      <div id="hint"><kbd>Arrows/WASD</kbd> move · <kbd>Space/Enter</kbd> talk/interact · <kbd>Q</kbd> docket · <kbd>I</kbd> case bag · <kbd>M</kbd> map</div>
    </div>
  </div>
</div>
<div id="touch-controls">
  <div id="dpad">
    <button class="up" data-key="ArrowUp">↑</button>
    <button class="down" data-key="ArrowDown">↓</button>
    <button class="left" data-key="ArrowLeft">←</button>
    <button class="right" data-key="ArrowRight">→</button>
  </div>
  <div id="action-buttons">
    <button class="spacebtn" data-key=" ">Space</button>
    <button class="qbtn" data-key="q">Q</button>
    <button class="ibtn" data-key="i">I</button>
  </div>
</div>
<script>
(() => {
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');
ctx.imageSmoothingEnabled = false;

const W = canvas.width, H = canvas.height;
let muted = false;
let bgMusicInterval = null;

function initAudio() {
  if (!audioCtx) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
}

function playSound(type) {
  if (muted || !audioCtx) return;
  initAudio();
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  osc.connect(gain);
  gain.connect(audioCtx.destination);
  
  switch(type) {
    case 'move':
      osc.frequency.value = 220;
      gain.gain.value = 0.05;
      osc.start();
      osc.stop(audioCtx.currentTime + 0.05);
      break;
    case 'interact':
      osc.frequency.value = 440;
      gain.gain.value = 0.1;
      osc.start();
      osc.stop(audioCtx.currentTime + 0.1);
      break;
    case 'coffee':
      osc.frequency.value = 523.25;
      gain.gain.value = 0.1;
      osc.start();
      osc.stop(audioCtx.currentTime + 0.15);
      break;
    case 'court':
      osc.frequency.value = 349.23;
      gain.gain.value = 0.1;
      osc.start();
      osc.stop(audioCtx.currentTime + 0.2);
      break;
    case 'quest':
      osc.frequency.value = 659.25;
      gain.gain.value = 0.1;
      osc.start();
      osc.stop(audioCtx.currentTime + 0.2);
      break;
  }
}

function toggleBgMusic() {
  if (bgMusicInterval) {
    clearInterval(bgMusicInterval);
    bgMusicInterval = null;
  } else {
    initAudio();
    let noteIdx = 0;
    const notes = [261.63, 329.63, 392.00, 523.25];
    bgMusicInterval = setInterval(() => {
      if (muted || !audioCtx) return;
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.frequency.value = notes[noteIdx % notes.length];
      gain.gain.value = 0.03;
      osc.start();
      osc.stop(audioCtx.currentTime + 0.3);
      noteIdx++;
    }, 500);
  }
}

function toggleMute() {
  muted = !muted;
  if (bgMusicInterval && muted) {
    clearInterval(bgMusicInterval);
    bgMusicInterval = null;
  }
}
};

const W = canvas.width, H = canvas.height;
const TILE_W = 64, TILE_H = 32;
const ORIGIN_X = W/2, ORIGIN_Y = 92;
const MAP_W = 18, MAP_H = 18;
const keys = {};
let showMap = false, showDocket = false, showCaseBag = false, showResult = false, showDaySummary = false, frame = 0;
let resultData = null;
let coffeeMiniGame = null; // { brewCount, brewTimer, active }

const state = {
  mode:'title',
  gold: 12,
  reputation: 0,
  stress: 0,
  coffee: 0,
  files: 0,
  evidence: 0,
  rightsMemo: 0,
  activeDialog: null,
  choiceMenu: null,
  flashMessage: null,
  flashTimer: 0,
  message: 'Press Space to begin Dr. A. Kulas adventure.',
  quests: {
    orientation:false, guide:false, friends:false, law:false, rights:false, court:false
  }
};

const player = { x: 8, y: 12, facing:'down', moving:false, bob:0, visualX:8, visualY:12, moveTimer:0 };
const MOVE_SPEED = 0.12; // tiles per frame — smooth walk

function iso(x,y,z=0){ return { x: ORIGIN_X + (x-y)*TILE_W/2, y: ORIGIN_Y + (x+y)*TILE_H/2 - z }; }
function tileAt(px,py){ return { x: Math.floor(px), y: Math.floor(py) }; }
function manhattan(a,b){ return Math.abs(a.x-b.x)+Math.abs(a.y-b.y); }

const tiles = Array.from({length:MAP_H}, (_,y)=>Array.from({length:MAP_W}, (_,x)=>{
  if (x===0||y===0||x===MAP_W-1||y===MAP_H-1) return 'wall';
  if ((x>1&&x<7&&y>1&&y<6) || (x>10&&x<16&&y>2&&y<7)) return 'building';
  if (x===8 || y===12 || (y===8&&x>3&&x<14)) return 'street';
  if ((x+y)%7===0) return 'cobble';
  return 'park';
}));
// Pig & Swine office interior-ish plaza
for (let y=9;y<13;y++) for (let x=3;x<8;x++) tiles[y][x]='office';
for (let x=4;x<7;x++) tiles[8][x]='street';
tiles[11][5]='desk'; tiles[10][6]='books'; tiles[9][4]='files';
// Court
for (let y=4;y<8;y++) for (let x=12;x<16;x++) tiles[y][x]='court';
tiles[7][14]='street';
// Cafe and tram stop
for (let y=13;y<16;y++) for (let x=11;x<15;x++) tiles[y][x]='cafe';
tiles[12][13]='street';
tiles[15][8]='tram';

function blocked(x,y){
  if (x<1||y<1||x>=MAP_W-1||y>=MAP_H-1) return true;
  return ['building','wall','desk','books'].includes(tiles[y][x]);
}

const npcs = [
  {id:'pig', name:'Mr. Pig', x:5, y:10, hue:'#c96c78',
    lines:()=>{
      if(state.quests.court) return ['Dr. A. Kula! Day One complete. Pig & Swine survives. Mr. Swine is still skiing.', 'The toner budget is safe. Justice, it seems, is billable.'];
      if(state.quests.rights) return ['You have the rights memo. Now go to court — defective service awaits.', 'Remember: fair hearing, proportionality, and Mr. Swine is still in Japan.'];
      if(state.quests.law) return ['You found the binder. Heavy, isnt it? Polish law always is.', 'Now find the human rights memo near the court. Dignity is just a filing away.'];
      if(state.quests.friends) return ['Rak and Wymysl are with you. Good. The firm needs a legal strike team.', 'Now find the Polish law binder in the office.'];
      if(state.quests.guide) return ['Muraś found. Good. He will guide you through Pig & Swine.', 'Find Rak and Wymysl next. They are your real friends.'];
      return ['Dr. A. Kula, welcome to Pig & Swine.', 'Our financial situation is very difficult. The firm is held together by coffee, unpaid invoices, and procedural optimism.', 'Mr. Swine is skiing in Japan, so you must help us survive Warsaw courts, Polish law, and human rights cases.', 'Find Muraś. He will guide you through the firm.'];
    },
    onTalk:()=>{ if(!state.quests.orientation){ state.quests.orientation=true; state.reputation++; saveGame(); } }},
  {id:'muras', name:'Muraś', x:4, y:11, hue:'#e0b35b',
    lines:()=>{
      // Track progress precisely
      if(state.quests.court) return ['Day One complete. The firm survives. Mr. Swine still skis.', 'Rest. Tomorrow brings new deadlines, new archives, new anxieties.'];
      if(state.quests.rights && !state.quests.court) return ['You have the rights memo! Now go to court — the Clerk awaits Dr. A. Kula.', 'Defective service, fair hearing, proportionality. You have all the pieces.'];
      if(state.quests.law && !state.quests.rights) return ['Excellent. The Polish law binder is heavy because justice requires gravity.', 'Now find the human rights memo near the court building. It explains dignity and proportionality.'];
      if(state.quests.friends && !state.quests.law) return ['Good. Rak and Wymysl are with you. The firm now has a legal strike team.', 'Next: collect the Polish law binder from the office. It explains why every simple matter has seven attachments.'];
      if(state.quests.guide && !state.quests.friends) return ['You found me. Now find Rak and Wymysl near the cafe.', 'They are your real friends — they will help with courts, Polish law, and human rights.'];
      return ['I am Muraś, your guide in Pig & Swine.', 'First rule: never enter the archive without a quest. Second rule: always know who your real friends are.', 'Find me near reception. If lost, follow the smell of binders.'];
    },
    onTalk:()=>{ if(!state.quests.guide){ state.quests.guide=true; saveGame(); } }},
  {id:'rak', name:'Rak', x:12, y:14, hue:'#7fb069',
    lines:()=>{
      if(state.quests.court) return ['Rak reporting. Day One complete. The archive grows, the deadlines multiply.', 'See you tomorrow, Dr. A. Kula. Bring coffee.'];
      if(state.quests.rights) return ['You have the memo! Now for court — defective service awaits.', 'I have spotted three missing annexes already. Classic Pig & Swine.'];
      if(state.quests.law) return ['Binder acquired. My sharp eyes approve.', 'Now find the human rights memo near the court. Dignity needs evidence.'];
      if(state.quests.friends) return ['Rak reporting for duty. I can spot a missing annex from across Warsaw.', 'eyes sharp, evidence and coffee ready.'];
      return ['Dr. A. Kula! We heard Pig & Swine is in trouble.', 'Wymysl and I are your real friends. We will help you sort facts from office folklore.'];
    }},
  {id:'wymysl', name:'Wymysl', x:14, y:14, hue:'#d7a84f',
    lines:()=>{
      if(state.quests.court) return ['Wymysl here. Day One done. Strategy proved correct.', 'Tomorrow: new cases, new chaos, same Swine in Japan.'];
      if(state.quests.rights) return ['Memo secured! The court will not know what hit it.', 'Strategy: defective service + human rights = victory.'];
      if(state.quests.law) return ['Binder found. Good. Now the human rights memo — near the court building.', 'Strategy: read the law, protect rights, avoid printer jams.'];
      if(state.quests.friends) return ['Wymysl here. Strategy: read the law, protect human rights, avoid printer jams.', 'theory brewing. Chaos to case in three steps.'];
      return ['A difficult financial situation? Classic Pig & Swine.', 'Gather Rak, me, and the binder. Then we go from chaos to case theory.'];
    }},
  {id:'clerk', name:'Court Clerk', x:14, y:6, hue:'#8bb1e0',
    lines:()=> state.quests.court
      ? ['The court quest is complete. Pig & Swine survives another docket.']
      : state.quests.law && state.quests.rights
      ? ['You have the binder, the rights memo, and a calm face. The court is ready for Dr. A. Kula.']
      : ['Court corridor rule: bring the right binder, the rights memo, and a calm face.', 'If you understand Polish law and human rights, the hearing may actually go well.']},
  {id:'tram', name:'Tram 17 Oracle', x:8, y:15, hue:'#e1d156',
    lines:()=> ['Ding ding. Warsaw wisdom: courts are near, deadlines are nearer.', 'Mr. Swine sends a postcard from Japan: “excellent powder, terrifying exchange rate.”']}
];

const items = [
  {id:'lawBinder', x:4, y:9, label:'Polish law binder', kind:'binder', taken:false},
  {id:'rightsMemo', x:9, y:7, label:'human rights memo', kind:'usb', taken:false}
];
const interactables = [
  {id:'coffeeMachine', name:'Coffee Machine', x:6, y:10, label:'Coffee Machine'}
];

function titleScreen(){
  ctx.fillStyle='#151827'; ctx.fillRect(0,0,W,H);
  drawPixelWarsawSkyline();
  ctx.textAlign='center';
  pixelText('PIG & SWINE', W/2, 132, 48, '#ffd76c', '#6d2f45');
  pixelText('DR. A. KULA IN WARSAW', W/2, 190, 24, '#f5ead2', '#22263a');
  drawLawyerSprite(W/2-24, 278, 3, '#33415f');
  drawPigSeal(W/2+88, 318, 2);
  box(170,410,620,136);
  writeWrapped('Dr. A. Kula begins at Pig & Swine: Mr. Pig warns of a very difficult financial situation while Mr. Swine skis in Japan. Find Rak, Wymysl, and Muraś to face courts, Polish law, and human rights.', 205,438,550,21,'#1b1f31');
  ctx.fillStyle = Math.floor(frame/25)%2 ? '#aa3d42' : '#1b1f31';
  ctx.font='20px monospace'; ctx.fillText('Press Space / Enter', W/2, 580);
}

function draw(){
  try {
  frame++;
  if (state.mode==='title') { titleScreen(); requestAnimationFrame(draw); return; }
  // Smooth movement interpolation
  if(player.visualX!==player.x||player.visualY!==player.y){
    const dx=player.x-player.visualX, dy=player.y-player.visualY;
    const step=MOVE_SPEED;
    player.visualX += Math.abs(dx)<step ? dx : Math.sign(dx)*step;
    player.visualY += Math.abs(dy)<step ? dy : Math.sign(dy)*step;
    player.moving=true; player.bob=Math.sin(frame/4)*2;
  } else { player.moving=false; player.bob=0; }
  ctx.clearRect(0,0,W,H);
  drawBackground();
  const entities = [];
  for (let y=0;y<MAP_H;y++) for (let x=0;x<MAP_W;x++) entities.push({type:'tile', x,y, sort:x+y, draw:()=>drawTile(x,y,tiles[y][x])});
  for (const item of items) if(!item.taken) entities.push({type:'item', x:item.x, y:item.y, sort:item.x+item.y+.2, draw:()=>drawItem(item)});
  for (const inter of interactables) entities.push({type:'interactable', x:inter.x, y:inter.y, sort:inter.x+inter.y+.3, draw:()=>drawInteractable(inter)});
  for (const n of npcs) entities.push({type:'npc', x:n.x, y:n.y, sort:n.x+n.y+.4, draw:()=>drawNPC(n)});
  entities.push({type:'player', x:player.visualX, y:player.visualY, sort:player.visualX+player.visualY+.5, draw:drawPlayer});
  entities.sort((a,b)=>a.sort-b.sort).forEach(e=>e.draw());
  drawInteractHint();
  drawHUD();
  if (state.flashMessage && state.flashTimer > 0){
    state.flashTimer--;
    ctx.save();
    ctx.fillStyle = 'rgba(82,111,69,.85)';
    ctx.fillRect(W/2-100, 20, 200, 40);
    ctx.strokeStyle='#d7a84f'; ctx.lineWidth=2; ctx.strokeRect(W/2-100, 20, 200, 40);
    ctx.fillStyle='#f5ead2'; ctx.font='18px monospace'; ctx.textAlign='center';
    ctx.fillText(state.flashMessage, W/2, 46);
    ctx.restore();
  }
  if (showMap) drawMiniMap();
  if (showDocket) drawDocket();
  if (showCaseBag) drawCaseBag();
  if (showResult) drawResultScreen();
  if (showDaySummary) drawDaySummary();
  if (state.choiceMenu) drawChoiceMenu();
  if (state.activeDialog) drawDialog();
  if (coffeeMiniGame && coffeeMiniGame.active) drawCoffeeMiniGame();
  requestAnimationFrame(draw);
  } catch(e) {
    ctx.fillStyle='#151827'; ctx.fillRect(0,0,W,H);
    ctx.fillStyle='#aa3d42'; ctx.font='16px monospace'; ctx.textAlign='left';
    ctx.fillText('JS Error: ' + e.message, 20, 40);
    ctx.fillText('Line: ' + (e.lineNumber||'unknown'), 20, 65);
    console.error('Draw error:', e);
    requestAnimationFrame(draw);
  }
}

function drawBackground(){
  const g = ctx.createLinearGradient(0,0,0,H);
  g.addColorStop(0,'#222943'); g.addColorStop(1,'#1a2134'); ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
  ctx.globalAlpha=.25; drawPixelWarsawSkyline(); ctx.globalAlpha=1;
}
function drawPixelWarsawSkyline(){
  ctx.fillStyle='#0e1120'; ctx.fillRect(0,360,W,280);
  const b=[60,90,50,130,70,105,44,160,70,88,55,118,40]; let x=35;
  b.forEach((h,i)=>{ ctx.fillRect(x,360-h,50,h); for(let yy=360-h+14; yy<348; yy+=18){ for(let xx=x+8; xx<x+44; xx+=16){ ctx.fillStyle=(i+yy+frame)%3?'#242b45':'#d7a84f'; ctx.fillRect(xx,yy,6,8); }} ctx.fillStyle='#0e1120'; x+=62; });
  ctx.fillStyle='#0e1120'; ctx.fillRect(730,170,56,190); ctx.fillRect(748,122,20,50); ctx.fillRect(755,92,6,36);
}

function drawTile(x,y,t){
  const p=iso(x,y);
  const palette={street:['#536176','#3c475c'], cobble:['#697077','#4e5966'], park:['#57734b','#3f5a38'], office:['#b99562','#7d543c'], cafe:['#8b6d4b','#5b4634'], court:['#c9c3ad','#8f897d'], tram:['#b6a83e','#6e692c'], files:['#b99562','#7d543c'], wall:['#303647','#202536'], building:['#41485f','#272d40'], desk:['#7b4b32','#43291f'], books:['#66563a','#332b26']};
  const [a,b]=palette[t]||palette.park;
  diamond(p.x,p.y,TILE_W,TILE_H,a,b);
  if (t==='building' || t==='court') drawBlock(p.x,p.y,t==='court'?'#d8d1bd':'#4f5872', t==='court'?'#aaa28e':'#303850', 42);
  if (t==='office') { ctx.fillStyle='#3e2b22'; ctx.fillRect(p.x-14,p.y-20,28,12); ctx.fillStyle='#ffd76c'; ctx.fillRect(p.x-8,p.y-17,16,4); }
  if (t==='cafe') { ctx.fillStyle='#2e2018'; ctx.fillRect(p.x-16,p.y-18,32,10); ctx.fillStyle='#f5ead2'; ctx.fillRect(p.x-11,p.y-16,22,5); }
  if (t==='tram') { ctx.fillStyle='#e1d156'; ctx.fillRect(p.x-22,p.y-23,44,16); ctx.fillStyle='#222'; ctx.fillRect(p.x-15,p.y-20,12,7); ctx.fillRect(p.x+4,p.y-20,12,7); }
}
function diamond(x,y,w,h,top,edge){
  ctx.fillStyle=top; ctx.beginPath(); ctx.moveTo(x,y-h/2); ctx.lineTo(x+w/2,y); ctx.lineTo(x,y+h/2); ctx.lineTo(x-w/2,y); ctx.closePath(); ctx.fill();
  ctx.strokeStyle=edge; ctx.lineWidth=2; ctx.stroke();
}
function drawBlock(x,y,front,side,h){
  ctx.fillStyle=side; ctx.beginPath(); ctx.moveTo(x+32,y); ctx.lineTo(x+32,y-h); ctx.lineTo(x,y+16-h); ctx.lineTo(x,y+16); ctx.closePath(); ctx.fill();
  ctx.fillStyle=front; ctx.beginPath(); ctx.moveTo(x-32,y); ctx.lineTo(x-32,y-h); ctx.lineTo(x,y+16-h); ctx.lineTo(x,y+16); ctx.closePath(); ctx.fill();
  ctx.fillStyle=lighten(front,18); ctx.beginPath(); ctx.moveTo(x,y-16-h); ctx.lineTo(x+32,y-h); ctx.lineTo(x,y+16-h); ctx.lineTo(x-32,y-h); ctx.closePath(); ctx.fill();
  ctx.strokeStyle='#202536'; ctx.stroke();
}
function lighten(hex, amt){ let n=parseInt(hex.slice(1),16); let r=Math.min(255,(n>>16)+amt),g=Math.min(255,((n>>8)&255)+amt),b=Math.min(255,(n&255)+amt); return `rgb(${r},${g},${b})`; }

function drawItem(item){
  const p=iso(item.x+.5,item.y+.5,18+Math.sin(frame/12)*3);
  ctx.save(); ctx.translate(p.x,p.y);
  ctx.fillStyle='rgba(255,215,108,.25)'; ctx.beginPath(); ctx.ellipse(0,20,22,8,0,0,Math.PI*2); ctx.fill();
  if(item.kind==='binder'){ ctx.fillStyle='#aa3d42'; ctx.fillRect(-13,-16,26,28); ctx.fillStyle='#f5ead2'; ctx.fillRect(-8,-10,16,4); ctx.fillRect(-8,-2,16,4); }
  else { ctx.fillStyle='#d7d8e0'; ctx.fillRect(-5,-14,10,24); ctx.fillStyle='#526f45'; ctx.fillRect(-3,-10,6,10); }
  ctx.restore();
}
function drawInteractable(inter){
  const p=iso(inter.x+.5,inter.y+.5,20+Math.sin(frame/10)*2);
  ctx.save(); ctx.translate(p.x,p.y);
  // Simple coffee machine sprite
  ctx.fillStyle='#59617f'; ctx.fillRect(-12,-16,24,28); // body
  ctx.fillStyle='#aa3d42'; ctx.fillRect(-8,-20,16,6); // top
  ctx.fillStyle='#d7a84f'; ctx.fillRect(-4,-12,8,4); // brew button
  ctx.fillStyle='#1b1f31'; ctx.fillRect(-6,-6,4,2); // display
  ctx.fillRect(2,-6,4,2);
  ctx.restore();
}
function drawNPC(n){ const p=iso(n.x+.5,n.y+.5,22); drawLawyerSprite(p.x-16,p.y-40,2,n.hue); }
function drawPlayer(){ const p=iso(player.visualX+.5,player.visualY+.5,23+Math.sin(frame/8)*2+player.bob); drawLawyerSprite(p.x-16,p.y-42,2.2,'#33415f'); }
function getNearbyInteractable(){
  for(const n of npcs) if(manhattan(player,n)<=1) return {type:'npc', name:n.name, x:n.x, y:n.y};
  for(const item of items) if(!item.taken && manhattan(player,item)<=1) return {type:'item', name:item.label, x:item.x, y:item.y, item};
  for(const inter of interactables) if(manhattan(player,inter)<=1) return {type:'interactable', name:inter.name, x:inter.x, y:inter.y, inter};
  return null;
}
function drawInteractHint(){
  const target = getNearbyInteractable();
  if(!target || state.activeDialog || state.mode==='title') return;
  const p=iso(target.x+.5,target.y+.5,58+Math.sin(frame/10)*4);
  ctx.save();
  ctx.textAlign='center';
  ctx.fillStyle='rgba(11,13,22,.82)';
  const label = target.type==='item' ? `Pick up ${target.item.label}` : target.type==='interactable' ? `Use ${target.name}` : `Talk to ${target.name}`;
  const text = `${label} · Press Space`;
  const width = Math.min(420, ctx.measureText(text).width + 26);
  ctx.fillRect(p.x-width/2, p.y-34, width, 28);
  ctx.strokeStyle='#ffd76c'; ctx.lineWidth=2; ctx.strokeRect(p.x-width/2, p.y-34, width, 28);
  ctx.fillStyle='#ffd76c'; ctx.font='16px monospace'; ctx.fillText(text, p.x, p.y-14);
  ctx.fillStyle='#f5ead2'; ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(p.x-8, p.y-10); ctx.lineTo(p.x+8, p.y-10); ctx.closePath(); ctx.fill();
  ctx.restore();
}
function drawLawyerSprite(x,y,s,coat){
  ctx.save(); ctx.translate(x,y); ctx.scale(s,s);
  ctx.fillStyle='#f1bd93'; ctx.fillRect(5,1,8,8); ctx.fillStyle='#2b1a12'; ctx.fillRect(4,0,10,3);
  ctx.fillStyle=coat; ctx.fillRect(3,9,12,14); ctx.fillStyle='#f5ead2'; ctx.fillRect(7,10,4,10); ctx.fillStyle='#aa3d42'; ctx.fillRect(8,13,2,7);
  ctx.fillStyle='#1b1f31'; ctx.fillRect(4,23,4,7); ctx.fillRect(11,23,4,7); ctx.fillStyle='#0b0d16'; ctx.fillRect(3,30,5,2); ctx.fillRect(11,30,5,2);
  ctx.restore();
}
function drawPigSeal(x,y,s){
  ctx.save(); ctx.translate(x,y); ctx.scale(s,s); ctx.fillStyle='#d88992'; ctx.fillRect(0,8,30,20); ctx.fillRect(5,2,6,8); ctx.fillRect(20,2,6,8); ctx.fillStyle='#b95f6b'; ctx.fillRect(9,15,12,8); ctx.fillStyle='#1b1f31'; ctx.fillRect(7,12,3,3); ctx.fillRect(21,12,3,3); ctx.restore();
}
function drawPortrait(npcId, x, y){
  ctx.save();
  ctx.translate(x, y);
  if(npcId === 'pig'){
    // Mr. Pig portrait - pink pig face
    ctx.fillStyle='#c96c78'; ctx.fillRect(4,4,24,24); // face
    ctx.fillStyle='#1b1f31'; ctx.fillRect(10,10,4,4); ctx.fillRect(20,10,4,4); // eyes
    ctx.fillStyle='#b95f6b'; ctx.fillRect(12,20,8,4); // nose/mouth
  } else if(npcId === 'muras'){
    // Muraś portrait - lawyer with glasses
    ctx.fillStyle='#e0b35b'; ctx.fillRect(4,8,24,20); // coat
    ctx.fillStyle='#f1bd93'; ctx.fillRect(10,4,12,12); // face
    ctx.fillStyle='#1b1f31'; ctx.fillRect(13,8,3,2); ctx.fillRect(20,8,3,2); // eyes
    ctx.fillStyle='#d7a84f'; ctx.fillRect(15,14,4,2); // glasses bridge
    ctx.fillStyle='#33415f'; ctx.fillRect(8,4,16,4); // hair
  } else if(npcId === 'rak'){
    // Rak portrait - sharp eyes
    ctx.fillStyle='#7fb069'; ctx.fillRect(4,8,24,20); // coat
    ctx.fillStyle='#f1bd93'; ctx.fillRect(10,4,12,12); // face
    ctx.fillStyle='#1b1f31'; ctx.fillRect(12,8,6,3); ctx.fillRect(20,8,6,3); // sharp eyes
    ctx.fillStyle='#33415f'; ctx.fillRect(8,4,16,4); // hair
  } else if(npcId === 'wymysl'){
    // Wymysl portrait - strategic thinker
    ctx.fillStyle='#d7a84f'; ctx.fillRect(4,8,24,20); // coat
    ctx.fillStyle='#f1bd93'; ctx.fillRect(10,4,12,12); // face
    ctx.fillStyle='#1b1f31'; ctx.fillRect(13,8,3,2); ctx.fillRect(20,8,3,2); // eyes
    ctx.fillStyle='#aa3d42'; ctx.fillRect(14,14,4,2); // serious mouth
    ctx.fillStyle='#33415f'; ctx.fillRect(8,4,16,4); // hair
  } else if(npcId === 'clerk'){
    // Court Clerk portrait - official
    ctx.fillStyle='#8bb1e0'; ctx.fillRect(4,8,24,20); // uniform
    ctx.fillStyle='#f1bd93'; ctx.fillRect(10,4,12,12); // face
    ctx.fillStyle='#1b1f31'; ctx.fillRect(13,8,3,2); ctx.fillRect(20,8,3,2); // eyes
    ctx.fillStyle='#1b1f31'; ctx.fillRect(14,14,4,2); // serious mouth
  } else {
    // Tram Oracle - mystical
    ctx.fillStyle='#e1d156'; ctx.fillRect(4,8,24,20); // coat
    ctx.fillStyle='#f1bd93'; ctx.fillRect(10,4,12,12); // face
    ctx.fillStyle='#1b1f31'; ctx.fillRect(13,8,3,2); ctx.fillRect(20,8,3,2); // eyes
    ctx.fillStyle='#d7a84f'; ctx.fillRect(14,14,4,2); // mystical smile
  }
  ctx.restore();
}
function drawBubble(x,y,text){ ctx.fillStyle='#f5ead2'; ctx.fillRect(x-10,y-14,20,16); ctx.fillStyle='#1b1f31'; ctx.font='14px monospace'; ctx.textAlign='center'; ctx.fillText(text,x,y-2); }

function drawHUD(){
  ctx.fillStyle='rgba(11,13,22,.84)'; ctx.fillRect(18,16,365,78);
  ctx.strokeStyle='#d7a84f'; ctx.strokeRect(18,16,365,78);
  ctx.font='16px monospace'; ctx.textAlign='left'; ctx.fillStyle='#f5ead2';
  ctx.fillText(`zł ${state.gold}   Reputation ${state.reputation}   Coffee ${state.coffee}`, 34,43);
  const q = nextQuest(); ctx.fillStyle='#ffd76c'; ctx.fillText(`Quest: ${q}`, 34,70);
}
function nextQuest(){
  if(!state.quests.orientation) return 'Speak with Mr. Pig about the financial crisis';
  if(!state.quests.guide) return 'Find Muraś, your guide through Pig & Swine';
  if(!state.quests.friends) return 'Find Rak and Wymysl, your real friends';
  if(!state.quests.law) return 'Collect the Polish law binder';
  if(!state.quests.rights) return 'Recover the human rights memo';
  if(!state.quests.court) return 'Go to court and save Pig & Swine';
  return 'Victory! Dr. A. Kula kept justice billable';
}
function box(x,y,w,h){ ctx.fillStyle='#f5ead2'; ctx.fillRect(x,y,w,h); ctx.strokeStyle='#1b1f31'; ctx.lineWidth=4; ctx.strokeRect(x,y,w,h); ctx.strokeStyle='#d7a84f'; ctx.lineWidth=2; ctx.strokeRect(x+7,y+7,w-14,h-14); }
function drawDialog(){
  box(70,466,820,138);
  ctx.fillStyle='#1b1f31'; ctx.font='18px monospace'; ctx.textAlign='left';
  // Draw portrait if NPC
  const hasPortrait = !!state.activeDialog.npcId;
  const textX = hasPortrait ? 120 : 100;
  const maxWidth = hasPortrait ? 720 : 760;
  const nextX = hasPortrait ? 650 : 690;
  if(hasPortrait){
    drawPortrait(state.activeDialog.npcId, 85, 476);
  }
  ctx.fillText(state.activeDialog.name, textX, 498);
  writeWrapped(state.activeDialog.text, textX, 528, maxWidth, 24, '#1b1f31');
  ctx.fillStyle='#aa3d42'; ctx.fillText('Space/Enter: next', nextX, 584);
}
function drawChoiceMenu(){
  const menu = state.choiceMenu;
  if(!menu) return;
  ctx.save();
  ctx.fillStyle='rgba(8,10,18,.70)'; ctx.fillRect(0,0,W,H);
  box(95,120,770,390);
  ctx.textAlign='left';
  ctx.fillStyle='#1b1f31'; ctx.font='24px monospace'; ctx.fillText(menu.title, 130,165);
  ctx.font='17px monospace'; writeWrapped(menu.prompt, 130,198,700,22,'#1b1f31');
  let y=270;
  menu.options.forEach((opt, idx)=>{
    ctx.fillStyle= idx===0 ? '#f1e2bf' : '#f7eed8'; ctx.fillRect(130,y-25,700,62);
    ctx.strokeStyle='#d7a84f'; ctx.strokeRect(130,y-25,700,62);
    ctx.fillStyle='#1b1f31'; ctx.font='16px monospace';
    writeWrapped(`${idx+1}. ${opt.text}`, 150, y, 660, 18, '#1b1f31');
    y += 76;
  });
  ctx.fillStyle='#aa3d42'; ctx.font='16px monospace'; ctx.fillText('Press 1, 2, or 3', 130,480);
  ctx.restore();
}
function writeWrapped(text,x,y,maxWidth,lineHeight,color){
  ctx.fillStyle=color; ctx.font='18px monospace'; const words=text.split(' '); let line='';
  for(const w of words){ const test=line+w+' '; if(ctx.measureText(test).width>maxWidth){ ctx.fillText(line,x,y); line=w+' '; y+=lineHeight; } else line=test; }
  ctx.fillText(line,x,y);
}
function pixelText(txt,x,y,size,fill,shadow){ ctx.font=`900 ${size}px monospace`; ctx.textAlign='center'; ctx.fillStyle=shadow; ctx.fillText(txt,x+4,y+4); ctx.fillStyle=fill; ctx.fillText(txt,x,y); }
function drawMiniMap(){
  const sx=732, sy=20, sc=7; ctx.fillStyle='rgba(11,13,22,.86)'; ctx.fillRect(sx-12,sy-12,154,154); ctx.strokeStyle='#ffd76c'; ctx.strokeRect(sx-12,sy-12,154,154);
  for(let y=0;y<MAP_H;y++) for(let x=0;x<MAP_W;x++){ ctx.fillStyle=blocked(x,y)?'#303647': tiles[y][x]==='street'?'#78869b':tiles[y][x]==='park'?'#526f45':'#b99562'; ctx.fillRect(sx+x*sc,sy+y*sc,sc-1,sc-1); }
  ctx.fillStyle='#ffd76c'; ctx.fillRect(sx+player.x*sc, sy+player.y*sc, sc, sc);
}
function questSteps(){
  return [
    {flag:'orientation', text:'Speak with Mr. Pig about the firm’s financial crisis'},
    {flag:'guide', text:'Find Muraś, your guide through Pig & Swine'},
    {flag:'friends', text:'Find Rak and Wymysl, Dr. A. Kula’s real friends'},
    {flag:'law', text:'Collect the Polish law binder'},
    {flag:'rights', text:'Recover the human rights memo'},
    {flag:'court', text:'Go to court and save Pig & Swine'}
  ];
}
function docketNote(){
  if(!state.quests.orientation) return 'Muraś note: Start with Mr. Pig. Panic is not a procedural remedy.';
  if(!state.quests.guide) return 'Muraś note: I am near reception. If lost, follow the smell of binders.';
  if(!state.quests.friends) return 'Muraś note: Find your friends before the firm mistakes you for office furniture.';
  if(!state.quests.law) return 'Muraś note: The binder is heavy because Polish law contains gravity.';
  if(!state.quests.rights) return 'Muraś note: Human rights arguments work best when actually brought to court.';
  if(!state.quests.court) return 'Muraś note: You have law, rights, and friends. That is almost a litigation strategy.';
  return 'Muraś note: Pig & Swine survives. For now. Mr. Swine remains in Japan.';
}
function drawDocket(){
  ctx.save();
  ctx.fillStyle='rgba(8,10,18,.72)'; ctx.fillRect(0,0,W,H);
  box(160,84,640,470);
  ctx.textAlign='left';
  ctx.fillStyle='#1b1f31'; ctx.font='28px monospace'; ctx.fillText('DOCKET: Day One — The Financial Crisis', 195,130);
  ctx.font='16px monospace'; ctx.fillStyle='#6d2f45'; ctx.fillText('Press Q to close · Pig & Swine internal case file', 195,158);
  const steps = questSteps();
  let y=190;
  for(const step of steps){
    const done = state.quests[step.flag];
    const mark = done ? '✓' : '□';
    ctx.fillStyle = done ? '#526f45' : (step.text===nextQuest() ? '#aa3d42' : '#1b1f31');
    ctx.font = done ? '18px monospace' : '19px monospace';
    ctx.fillText(`${mark} ${step.text}`, 205, y);
    y += 34;
  }
  ctx.fillStyle='#f1e2bf'; ctx.fillRect(195,405,570,92);
  ctx.strokeStyle='#d7a84f'; ctx.lineWidth=2; ctx.strokeRect(195,405,570,92);
  writeWrapped(docketNote(), 215,435,530,23,'#1b1f31');
  ctx.fillStyle='#6d2f45'; ctx.font='15px monospace';
  ctx.fillText(`Firm Liquidity: zł ${state.gold}   Bar Reputation: ${state.reputation}`, 215,520);
  ctx.restore();
}
function caseBagItems(){
  return [
    {name:'Polish law binder', owned:state.quests.law, desc:'A sacred red binder. Heavy enough to support legal arguments and unstable furniture.'},
    {name:'human rights memo', owned:state.quests.rights, desc:'Notes on dignity, fair trial, proportionality, and why bureaucracy should fear Dr. A. Kula.'},
    {name:'Coffee reserve', owned:state.coffee>0, desc:state.coffee>0 ? 'Procedural fuel. The true source of interim relief.' : 'Empty. Dangerous for both deadlines and morale.'},
    {name:'Mr. Swine postcard', owned:true, desc:'Greetings from Japan: excellent powder, alarming expenses, unclear comparative-law value.'}
  ];
}
function drawCaseBag(){
  ctx.save();
  ctx.fillStyle='rgba(8,10,18,.72)'; ctx.fillRect(0,0,W,H);
  box(130,70,700,500);
  ctx.textAlign='left';
  ctx.fillStyle='#1b1f31'; ctx.font='30px monospace'; ctx.fillText('CASE BAG', 175,120);
  ctx.font='16px monospace'; ctx.fillStyle='#6d2f45'; ctx.fillText('Press I to close · Evidence, notes, and survival objects', 175,150);
  ctx.fillStyle='#f1e2bf'; ctx.fillRect(170,178,600,66);
  ctx.strokeStyle='#d7a84f'; ctx.lineWidth=2; ctx.strokeRect(170,178,600,66);
  ctx.fillStyle='#1b1f31'; ctx.font='16px monospace';
  ctx.fillText(`Firm Liquidity: zł ${state.gold}`, 195,205);
  ctx.fillText(`Bar Reputation: ${state.reputation}`, 430,205);
  ctx.fillText(`Procedural Anxiety: ${state.stress}`, 195,230);
  ctx.fillText(`Coffee: ${state.coffee}`, 430,230);
  let y=285;
  for(const item of caseBagItems()){
    ctx.fillStyle = item.owned ? '#526f45' : '#7b7f8e';
