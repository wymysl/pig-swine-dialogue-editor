    ctx.fillStyle='#1b1f31'; ctx.font='15px monospace';
    writeWrapped(item.desc, 205, y+24, 545, 19, item.owned ? '#1b1f31' : '#59617f');
    y += 60;
  }
  writeWrapped('Muraś says: A good case bag contains law, facts, and one snack nobody admits owning.', 175,530,600,18,'#aa3d42');
  ctx.fillStyle='#1b1f31'; ctx.font='14px monospace'; ctx.textAlign='center';
  ctx.fillText('S: Save Game   L: Load Game   B: Music   Ctrl+M: Mute', W/2, 555);
  ctx.restore();
}

function drawResultScreen(){
  ctx.save();
  ctx.fillStyle='rgba(8,10,18,.82)'; ctx.fillRect(0,0,W,H);
  // Main panel
  box(120,60,720,520);
  ctx.textAlign='center';
  // Victory / Failure header
  const victory = resultData && resultData.victory;
  ctx.fillStyle = victory ? '#526f45' : '#aa3d42';
  ctx.font='900 36px monospace';
  ctx.fillText(victory ? '⚖️  CASE RESULT  ⚖️' : '⚖️  CASE DISMISSED  ⚖️', W/2, 110);

  ctx.textAlign='left';
  ctx.font='20px monospace';
  // Argument quality
  ctx.fillStyle='#1b1f31';
  ctx.fillText('Argument Quality:', 175, 160);
  ctx.fillStyle = victory ? '#526f45' : '#aa3d42';
  ctx.fillText(victory ? 'Strong — legally grounded' : 'Weak — comedically grounded', 420, 160);

  ctx.fillStyle='#1b1f31';
  ctx.fillText('Human Rights Angle:', 175, 195);
  ctx.fillStyle = victory ? '#526f45' : '#7b7f8e';
  ctx.fillText(victory ? 'Persuasive — proportionality cited' : 'Absent — Mr. Swine cited instead', 420, 195);

  ctx.fillText('Defective Service:', 175, 230);
  ctx.fillStyle = victory ? '#526f45' : '#7b7f8e';
  ctx.fillText(victory ? 'Identified — fair hearing affected' : 'Ignored — emotional printers cited', 420, 230);

  // Stat deltas box
  ctx.fillStyle='#f1e2bf'; ctx.fillRect(165,260,630,100);
  ctx.strokeStyle='#d7a84f'; ctx.lineWidth=2; ctx.strokeRect(165,260,630,100);
  ctx.font='22px monospace'; ctx.textAlign='center';
  if(victory){
    ctx.fillStyle='#526f45'; ctx.fillText('Firm Liquidity: +20 zł', W/2-150, 300);
    ctx.fillText('Bar Reputation: +3', W/2+150, 300);
    ctx.fillStyle='#1b1f31'; ctx.fillText('Procedural Anxiety: 0', W/2, 340);
  } else {
    ctx.fillStyle='#aa3d42'; ctx.fillText('Firm Liquidity: +0 zł', W/2-150, 300);
    ctx.fillText('Bar Reputation: +0', W/2+150, 300);
    ctx.fillText('Procedural Anxiety: +1', W/2, 340);
  }

  // Mr. Pig reaction
  ctx.textAlign='left';
  ctx.fillStyle='#f1e2bf'; ctx.fillRect(165,385,630,110);
  ctx.strokeStyle='#c96c78'; ctx.lineWidth=2; ctx.strokeRect(165,385,630,110);
  drawPigSeal(195,420,1.5);
  ctx.fillStyle='#1b1f31'; ctx.font='18px monospace';
  ctx.fillText('Mr. Pig:', 248, 410);
  ctx.font='17px monospace';
  if(victory){
    writeWrapped('"We may yet afford toner. Mr. Swine will receive a fax about this victory — if he ever leaves the slopes."', 248, 435, 520, 21, '#1b1f31');
  } else {
    writeWrapped('"That was not a legal argument. That was a holiday postcard. Try again before the court loses all patience."', 248, 435, 520, 21, '#aa3d42');
  }

  // Footer
  ctx.textAlign='center';
  ctx.fillStyle= Math.floor(frame/20)%2 ? '#aa3d42' : '#1b1f31';
  ctx.font='18px monospace';
  ctx.fillText(victory ? 'Press Space to continue — Day One complete' : 'Press Space to try again', W/2, 545);
  ctx.restore();
}

function drawDaySummary(){
  ctx.save();
  ctx.fillStyle='rgba(8,10,18,.92)'; ctx.fillRect(0,0,W,H);
  // Draw faint skyline
  ctx.globalAlpha=.15; drawPixelWarsawSkyline(); ctx.globalAlpha=1;
  // Main panel
  box(100,40,760,560);
  ctx.textAlign='center';

  // Header
  ctx.fillStyle='#d7a84f'; ctx.font='900 32px monospace';
  ctx.fillText('DAY ONE COMPLETE', W/2, 88);
  ctx.fillStyle='#aa3d42'; ctx.font='22px monospace';
  ctx.fillText('Dr. A. Kula — Pig & Swine, Warsaw', W/2, 120);

  // Narrative summary
  ctx.textAlign='left';
  const lines = [
    'Dr. A. Kula arrived at Pig & Swine on the worst possible morning.',
    'Mr. Pig confirmed the financial crisis. Mr. Swine remained in Japan.',
    'Muraś guided the way. Rak and Wymysl proved their loyalty.',
    'A Polish law binder was found. A human rights memo was recovered.',
    'In court, Dr. A. Kula argued that defective service violated',
    'the right to a fair hearing — and the court agreed.',
    '',
    'Pig & Swine survives. For now.'
  ];
  let y = 165;
  for(const line of lines){
    ctx.fillStyle = line==='' ? '#1b1f31' : '#1b1f31';
    ctx.font = line.startsWith('Pig & Swine') ? '900 20px monospace' : '18px monospace';
    if(line!=='') ctx.fillText(line, 150, y);
    y += 28;
  }

  // Final stats box
  ctx.fillStyle='#f1e2bf'; ctx.fillRect(145,400,670,80);
  ctx.strokeStyle='#d7a84f'; ctx.lineWidth=2; ctx.strokeRect(145,400,670,80);
  ctx.font='20px monospace'; ctx.textAlign='center';
  ctx.fillStyle='#526f45'; ctx.fillText(`Firm Liquidity: zł ${state.gold}`, W/2-180, 435);
  ctx.fillText(`Bar Reputation: ${state.reputation}`, W/2+180, 435);
  ctx.fillStyle='#1b1f31'; ctx.fillText(`Quests Completed: ${Object.values(state.quests).filter(v=>v).length}/6`, W/2, 465);

  // Muraś epilogue
  ctx.textAlign='left';
  ctx.fillStyle='#aa3d42'; ctx.font='17px monospace';
  writeWrapped('Muraś note: Day One is done. Tomorrow the deadlines return, the archive grows, and Mr. Swine will still be skiing. Rest while you can.', 150, 510, 660, 21, '#aa3d42');

  // Footer
  ctx.textAlign='center';
  ctx.fillStyle= Math.floor(frame/22)%2 ? '#d7a84f' : '#1b1f31';
  ctx.font='18px monospace';
  ctx.fillText('Press Space to return to Warsaw', W/2, 580);
  ctx.restore();
}

// Save/Load System
function saveGame(){
  const saveData = {
    state: {
      gold: state.gold,
      reputation: state.reputation,
      stress: state.stress,
      coffee: state.coffee,
      files: state.files,
      evidence: state.evidence,
      rightsMemo: state.rightsMemo,
      quests: {...state.quests}
    },
    player: {
      x: player.x,
      y: player.y,
      facing: player.facing
    },
    timestamp: Date.now()
  };
  try {
    localStorage.setItem('pigSwineSave', JSON.stringify(saveData));
    showSaveFlash();
    console.log('Game saved');
  } catch(e) {
    console.error('Save failed:', e);
  }
}

function loadGame(){
  const saveStr = localStorage.getItem('pigSwineSave');
  if(!saveStr) return false;
  try {
    const saveData = JSON.parse(saveStr);
    // Restore state
    Object.assign(state, saveData.state);
    // Restore player position
    Object.assign(player, saveData.player);
    player.visualX = player.x;
    player.visualY = player.y;
    player.moving = false;
    state.mode = 'play';
    state.activeDialog = null;
    state.choiceMenu = null;
    showResult = false;
    showDaySummary = false;
    console.log('Game loaded');
    return true;
  } catch(e) {
    console.error('Load failed:', e);
    return false;
  }
}

function showSaveFlash(){
  state.flashMessage = 'Game Saved!';
  state.flashTimer = 90; // ~1.5 seconds at 60fps
}

function checkLoadOnStart(){
  if(localStorage.getItem('pigSwineSave')){
    state.mode = 'play';
    loadGame();
  }
}

function interact(){ playSound("interact"); playSound("interact");
  if(state.mode==='title'){ startOpeningScene(); return; }
  if(showDaySummary){ showDaySummary=false; return; }
  if(showResult){
    const wasVictory = resultData && resultData.victory;
    showResult=false; resultData=null;
    if(wasVictory){ showDaySummary=true; }
    return;
  }
  if(state.activeDialog){ advanceDialog(); return; }
  for(const n of npcs){ if(manhattan(player,n)<=1){ startDialog(n); return; }}
  for(const item of items){ if(!item.taken && manhattan(player,item)<=1){ takeItem(item); return; }}
  for(const inter of interactables){ if(manhattan(player,inter)<=1){ startCoffeeMiniGame(); return; }}
  state.message='Nothing billable here.';
}
function startOpeningScene(){
  state.mode='play';
  if(!state.quests.orientation){ state.quests.orientation=true; state.reputation++; }
  const lines=[
    'Welcome to Pig & Swine, Dr. A. Kula.',
    'Our financial situation is very difficult. Justice may be priceless, but rent has an invoice number.',
    'Mr. Swine is skiing in Japan, allegedly studying comparative snow liability.',
    'Find Muraś near reception. He will guide you through courts, Polish law, human rights, and the printer.'
  ];
  state.activeDialog={ name:'Mr. Pig', lines, idx:0, text:lines[0] };
}
function startDialog(n){
  if(n.onTalk) n.onTalk();
  if((n.id==='rak' || n.id==='wymysl') && !state.quests.friends){
    const rakClose = manhattan(player, npcs.find(p=>p.id==='rak'))<=2;
    const wymyslClose = manhattan(player, npcs.find(p=>p.id==='wymysl'))<=2;
    if(rakClose || wymyslClose){ state.quests.friends=true; state.reputation++; saveGame(); }
  }
  if(n.id==='clerk' && state.quests.law && state.quests.rights && !state.quests.court){ startCourtArgumentChoice(); return; }
  const lines=n.lines(); state.activeDialog={ name:n.name, npcId: n.id, lines, idx:0, text:lines[0] };
  saveGame();
}
function advanceDialog(){ const d=state.activeDialog; d.idx++; if(d.idx>=d.lines.length) state.activeDialog=null; else d.text=d.lines[d.idx]; }
function startCourtArgumentChoice(){
  state.choiceMenu={
    title:'Court Argument — Urgent Filing',
    prompt:'Court Clerk: Dr. A. Kula, why should the court accept this filing despite the procedural chaos?',
    options:[
      {correct:true, text:'Because defective service affected the right to a fair hearing, and the human rights memo supports proportionality.'},
      {correct:false, text:'Because Pig & Swine has a difficult financial situation and the printer suffered emotionally.'},
      {correct:false, text:'Because Mr. Swine is skiing in Japan and cannot be expected to process defeat across time zones.'}
    ]
  };
}
function resolveCourtChoice(index){ playSound("court");
  if(!state.choiceMenu) return;
  const opt=state.choiceMenu.options[index];
  state.choiceMenu=null;
  if(!opt) return;
  if(opt.correct){
    state.quests.court=true; playSound("quest");; state.reputation+=3; state.gold+=20;
    resultData = { victory: true };
    showResult = true;
    saveGame();
  } else {
    state.stress+=1;
    resultData = { victory: false };
    showResult = true;
  }
}
function takeItem(item){ item.taken=true;
  if(item.id==='lawBinder'){ state.files++; state.quests.law=true; state.reputation++; flashDialog('You found the Polish law binder: civil procedure, constitutional principles, and twelve colored tabs.'); saveGame(); }
  if(item.id==='rightsMemo'){ state.rightsMemo++; state.quests.rights=true; state.reputation++; flashDialog('Human rights memo recovered. Dr. A. Kula now has arguments about dignity, fair trial, and proportionality.'); saveGame(); }
function startCoffeeMiniGame(){ playSound("coffee"); playSound("coffee");
  coffeeMiniGame = { brewCount:0, brewTimer:300, active:true }; // 5s at 60fps
  // Add click handler for brew button
  canvas._coffeeClick = function(e){
    if(!coffeeMiniGame || !coffeeMiniGame.active) { canvas.removeEventListener('click', canvas._coffeeClick); return; }
    const rect = canvas.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    const btnX = W/2 - 60, btnY = 300, btnW = 120, btnH = 50;
    if(x >= btnX && x <= btnX + btnW && y >= btnY && y <= btnY + btnH){
      clickBrewButton();
    }
  };
  canvas.addEventListener('click', canvas._coffeeClick);
}
function drawCoffeeMiniGame(){
  if(!coffeeMiniGame || !coffeeMiniGame.active) return;
  ctx.save();
  ctx.fillStyle='rgba(8,10,18,.85)';
  ctx.fillRect(0,0,W,H);
  box(200,150,560,340);
  ctx.textAlign='center';
  ctx.fillStyle='#1b1f31';
  ctx.font='28px monospace';
  ctx.fillText('BREW COFFEE', W/2, 200);
  ctx.font='18px monospace';
  writeWrapped('Click the brew button 3 times within 5 seconds to brew coffee. Reduces Procedural Anxiety by 10.', 250, 230, 460, 22, '#1b1f31');
  // Brew button
  const btnX = W/2 - 60, btnY = 300, btnW = 120, btnH = 50;
  ctx.fillStyle= Math.floor(frame/10)%2 ? '#d7a84f' : '#c96c78';
  ctx.fillRect(btnX, btnY, btnW, btnH);
  ctx.strokeStyle='#ffd76c'; ctx.lineWidth=2; ctx.strokeRect(btnX, btnY, btnW, btnH);
  ctx.fillStyle='#1b1f31'; ctx.font='20px monospace';
  ctx.fillText('BREW', W/2, btnY + 32);
  // Progress
  ctx.fillStyle='#526f45'; ctx.font='18px monospace';
  ctx.fillText(`Brewed: ${coffeeMiniGame.brewCount}/3`, W/2, 380);
  // Timer
  ctx.fillStyle='#aa3d42';
  ctx.fillText(`Time left: ${Math.ceil(coffeeMiniGame.brewTimer/60)}s`, W/2, 410);
  // Update timer
  coffeeMiniGame.brewTimer--;
  if(coffeeMiniGame.brewTimer <= 0) resolveCoffeeMiniGame(false);
  ctx.restore();
}
function resolveCoffeeMiniGame(success){
  if(!coffeeMiniGame) return;
  coffeeMiniGame.active = false;
  if(success){
    state.stress = Math.max(0, state.stress - 10);
    state.coffee++;
    state.reputation++;
    flashDialog('Coffee brewed! Procedural Anxiety reduced by 10. Mr. Pig would be proud — if he weren\'t busy panicking about rent.');
    saveGame();
  } else {
    flashDialog('Coffee spilled! The machine hisses. Mr. Pig shouts: "That was our last filter!"');
  }
  coffeeMiniGame = null;
  if(canvas._coffeeClick) canvas.removeEventListener('click', canvas._coffeeClick);
}
function clickBrewButton(){
  if(!coffeeMiniGame || !coffeeMiniGame.active) return;
  coffeeMiniGame.brewCount++;
  if(coffeeMiniGame.brewCount >= 3) resolveCoffeeMiniGame(true);
}
function flashDialog(text){ state.activeDialog={ name:'Discovery', lines:[text], idx:0, text}; }

function tryMove(dx,dy,face){ playSound("move");
  if(state.activeDialog || state.mode==='title') return; player.facing=face;
  const nx=player.x+dx, ny=player.y+dy; if(!blocked(nx,ny)){ player.x=nx; player.y=ny; }
}
window.addEventListener('keydown', e=>{
  if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight',' ','Enter'].includes(e.key)) e.preventDefault();
  if(showResult && (e.key===' '||e.key==='Enter')){ interact(); return; }
  if(showResult) return;
  if(showDaySummary && (e.key===' '||e.key==='Enter')){ interact(); return; }
  if(showDaySummary) return;
  if(state.activeDialog && (e.key.toLowerCase()==='q' || e.key.toLowerCase()==='i')) return;
  if(state.choiceMenu && ['1','2','3'].includes(e.key)){ resolveCourtChoice(Number(e.key)-1); return; }
  if(state.choiceMenu) return;
  if(e.key.toLowerCase()==='q' && state.mode!=='title') { showDocket=!showDocket; if(showDocket) showCaseBag=false; return; }
  if(e.key.toLowerCase()==='i' && state.mode!=='title') { showCaseBag=!showCaseBag; if(showCaseBag) showDocket=false; return; }
  if(showDocket || (showCaseBag && !['s','l'].includes(e.key.toLowerCase()))) return;
  if(showCaseBag && e.key.toLowerCase()==='s'){ saveGame(); return; }
  if(showCaseBag && e.key.toLowerCase()==='l'){ loadGame(); return; }
  if(e.key===' '||e.key==='Enter') interact();
  if(e.key.toLowerCase()==='m' && e.ctrlKey) { toggleMute(); return; }
  if(e.key.toLowerCase()==='b') toggleBgMusic();
  if(e.key.toLowerCase()==='m') showMap=!showMap;
  keys[e.key]=true;
});
window.addEventListener('keyup', e=>{ delete keys[e.key]; });

// Touch controls: map button touches to keyboard events
document.querySelectorAll('#touch-controls button').forEach(btn => {
  const key = btn.dataset.key;
  btn.addEventListener('touchstart', e => {
    e.preventDefault();
    document.dispatchEvent(new KeyboardEvent('keydown', {key, bubbles:true}));
    btn.style.background = 'rgba(215,168,79,.9)';
  });
  btn.addEventListener('touchend', e => {
    e.preventDefault();
    document.dispatchEvent(new KeyboardEvent('keyup', {key, bubbles:true}));
    btn.style.background = '';
  });
  // Also handle mouse events for desktop testing
  btn.addEventListener('mousedown', e => {
    document.dispatchEvent(new KeyboardEvent('keydown', {key, bubbles:true}));
    btn.style.background = 'rgba(215,168,79,.9)';
  });
  btn.addEventListener('mouseup', e => {
    document.dispatchEvent(new KeyboardEvent('keyup', {key, bubbles:true}));
    btn.style.background = '';
  });
});

// Held-key movement tick (smooth walking)
let moveCooldown=0;
setInterval(()=>{
  if(state.activeDialog||state.mode==='title'||showDocket||showCaseBag||state.choiceMenu||showResult||showDaySummary) return;
  if(moveCooldown>0){ moveCooldown--; return; }
  if(keys['ArrowUp']||keys['w']||keys['W']){ tryMove(0,-1,'up'); moveCooldown=2; }
  else if(keys['ArrowDown']||keys['s']||keys['S']){ tryMove(0,1,'down'); moveCooldown=2; }
  else if(keys['ArrowLeft']||keys['a']||keys['A']){ tryMove(-1,0,'left'); moveCooldown=2; }
  else if(keys['ArrowRight']||keys['d']||keys['D']){ tryMove(1,0,'right'); moveCooldown=2; }
}, 60);

window.__pigDebug = { state, player, startCourtArgumentChoice, resolveCourtChoice, questSteps, caseBagItems };

checkLoadOnStart();
draw();
}
})();
</script>
</body>
</html>
