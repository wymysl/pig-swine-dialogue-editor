extends SceneTree
## tests/test_dialogue_runner.gd — unit tests for DialogueRunner predicate evaluation
## and line selection logic.
##
## Runs entirely headless: no window, no rendered frames.
## Tests load the fixture JSON and drive _evaluate_trigger / _on_dialogue_requested
## directly.

const FIXTURE_PATH: String = "res://tests/fixtures/dialogue_fixture.json"

var _pass_count: int = 0
var _fail_count: int = 0

## Capture buffers for signal results (Array avoids closure-capture issues).
var _signal_capture: Array = ["", []]  ## [speaker, lines]

## Minimal State stub so DialogueRunner can call State.data
## The real State autoload should be available via the project settings.


func _init() -> void:
	print("[TestDialogueRunner] Starting...")
	await process_frame

	## Instantiate a bare DialogueRunner node.
	var runner_scene := load("res://scripts/autoload/dialogue_runner.gd") as GDScript
	if runner_scene == null:
		_fail("Could not load dialogue_runner.gd")
		_finish()
		return

	var runner := Node.new()
	runner.set_script(runner_scene)
	get_root().add_child(runner)
	## (await removed — --quit ends after frame 1; signals fire synchronously)

	## Manually inject fixture data into runner's catalogue (bypass file I/O).
	var fixture_text: String = ""
	var f := FileAccess.open(FIXTURE_PATH, FileAccess.READ)
	if f == null:
		_fail("Could not open fixture: " + FIXTURE_PATH)
		_finish()
		return
	fixture_text = f.get_as_text()
	f.close()

	var fixture = JSON.parse_string(fixture_text)
	if fixture == null:
		_fail("Fixture JSON parse failed")
		_finish()
		return
	runner._catalogue["test_npc"] = fixture

	## -----------------------------------------------------------------------
	## Test 1: trigger "chapter1.met_pig == false" passes when met_pig is false
	## -----------------------------------------------------------------------
	var state_node = get_root().get_node_or_null("/root/State")
	if state_node == null:
		_fail("State autoload not available — cannot run trigger tests")
		_finish()
		return
	state_node.data["chapter1"]["met_pig"] = false
	var result: bool = runner._evaluate_trigger("chapter1.met_pig == false")
	if result:
		_pass("T1: trigger 'met_pig == false' returns true when State is false")
	else:
		_fail("T1: trigger 'met_pig == false' should return true but returned false")

	## -----------------------------------------------------------------------
	## Test 2: trigger "chapter1.met_pig == true" fails when met_pig is false
	## -----------------------------------------------------------------------
	result = runner._evaluate_trigger("chapter1.met_pig == true")
	if not result:
		_pass("T2: trigger 'met_pig == true' returns false when State is false")
	else:
		_fail("T2: trigger 'met_pig == true' should return false but returned true")

	## -----------------------------------------------------------------------
	## Test 3: compound trigger passes when both sides are correct
	## -----------------------------------------------------------------------
	state_node.data["chapter1"]["met_pig"] = true
	state_node.data["chapter1"]["met_murrow"] = false
	result = runner._evaluate_trigger("chapter1.met_pig == true && chapter1.met_murrow == false")
	if result:
		_pass("T3: compound trigger (met_pig==true && met_murrow==false) passes correctly")
	else:
		_fail("T3: compound trigger should pass but returned false")

	## -----------------------------------------------------------------------
	## Test 4: line selection picks first passing state
	## -----------------------------------------------------------------------
	state_node.data["chapter1"]["met_pig"] = false
	state_node.data["chapter1"]["met_murrow"] = false
	var sigs = get_root().get_node_or_null("/root/Signals")
	if sigs == null:
		_fail("T4: Signals autoload not available")
		_finish()
		return
	_signal_capture[0] = ""
	_signal_capture[1] = []
	var capture := _signal_capture  ## named ref so lambda captures correctly
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture[0] = s
		capture[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("test_npc", "Test NPC")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	if _signal_capture[1].size() > 0 and _signal_capture[1][0] == "Pig has not been met.":
		_pass("T4: first matching state line selected (met_pig==false -> 'Pig has not been met.')")
	else:
		_fail("T4: expected 'Pig has not been met.' but got: " + str(_signal_capture[1]))

	## -----------------------------------------------------------------------
	## Test 5: empty trigger always passes (first unconditional state matched)
	## -----------------------------------------------------------------------
	result = runner._evaluate_trigger("")
	if result:
		_pass("T5: empty trigger always passes")
	else:
		_fail("T5: empty trigger should always pass")

	## -----------------------------------------------------------------------
	## Test 6: idle_flavor returned when no state trigger passes
	## -----------------------------------------------------------------------
	## Fixture states:
	##   1. has_law_binder==true  (fails when binder=false)
	##   2. met_pig==false        (fails when pig=true)
	##   3. met_pig==true && met_murrow==false  (fails when murrow=true)
	## Set: pig=true, murrow=true, binder=false → all fail → idle_flavor.
	state_node.data["chapter1"]["met_pig"] = true
	state_node.data["chapter1"]["met_murrow"] = true
	state_node.data["chapter1"]["has_law_binder"] = false
	_signal_capture[1] = []
	var capture2 := _signal_capture
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture2[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("test_npc", "Test NPC")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	if _signal_capture[1].size() > 0 and _signal_capture[1][0] in ["Idle line A.", "Idle line B."]:
		_pass("T6: idle_flavor returned when no state trigger matches")
	else:
		_fail("T6: expected idle_flavor line but got: " + str(_signal_capture[1]))

	## -----------------------------------------------------------------------
	## Test 7: on_dismiss mutation
	## -----------------------------------------------------------------------
	state_node.data["chapter1"]["met_pig"] = false
	runner._on_dialogue_requested("test_npc", "Test NPC")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	sigs.dialogue_dismissed.emit()
	if state_node.data["chapter1"]["met_pig"] == true:
		_pass("T7: on_dismiss hook successfully mutated state")
	else:
		_fail("T7: on_dismiss hook did not mutate state")

	## -----------------------------------------------------------------------
	## Test 8: multi-line dialogue parsing
	## -----------------------------------------------------------------------
	state_node.data["chapter1"]["met_pig"] = true
	state_node.data["chapter1"]["met_murrow"] = false
	var capture3 := _signal_capture
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture3[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("test_npc", "Test NPC")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	if _signal_capture[1].size() == 2 and _signal_capture[1][1] == "Page two.":
		_pass("T8: multi-line dialogue correctly resolved to Array")
	else:
		_fail("T8: expected multi-line array but got: " + str(_signal_capture[1]))

	## -----------------------------------------------------------------------
	## T9–T12: Multi-speaker extension tests (option 1).
	## Load multi_speaker_fixture.json and inject under "test_npc_multi".
	## -----------------------------------------------------------------------
	const MULTI_FIXTURE_PATH: String = "res://tests/fixtures/multi_speaker_fixture.json"
	var mf := FileAccess.open(MULTI_FIXTURE_PATH, FileAccess.READ)
	if mf == null:
		_fail("T9: Could not open multi_speaker_fixture.json")
		_finish()
		return
	var multi_fixture = JSON.parse_string(mf.get_as_text())
	mf.close()
	if multi_fixture == null:
		_fail("T9: multi_speaker_fixture.json parse failed")
		_finish()
		return
	runner._catalogue["test_npc_multi"] = multi_fixture

	## -----------------------------------------------------------------------
	## Test 9: mixed lines array contains strings and dicts in correct order
	## -----------------------------------------------------------------------
	## The fixture state "test_multi" fires when met_pig == false.
	state_node.data["chapter1"]["met_pig"] = false
	var capture9 := _signal_capture
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture9[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("test_npc_multi", "Test NPC Multi")
	## (await removed — --quit ends after frame 1; signals fire synchronously)

	var lines9: Array = _signal_capture[1]
	var t9_ok: bool = (
		lines9.size() == 4
		and lines9[0] is String and lines9[0] == "Owning NPC speaks first."
		and lines9[1] is Dictionary and lines9[1].get("speaker") == "cula" and lines9[1].get("text") == "Cula responds."
		and lines9[2] is String and lines9[2] == "Owning NPC speaks again."
		and lines9[3] is Dictionary and lines9[3].get("speaker") == "asia" and lines9[3].get("text") == "Asia chimes in."
	)
	if t9_ok:
		_pass("T9: mixed lines array fires 4 entries in correct order (strings and dicts)")
	else:
		_fail("T9: mixed lines array incorrect; got: " + str(lines9))

	## -----------------------------------------------------------------------
	## Test 10: trigger evaluation works for multi-speaker state
	## -----------------------------------------------------------------------
	## met_pig == true → state trigger fails → falls to idle_flavor.
	state_node.data["chapter1"]["met_pig"] = true
	var capture10 := _signal_capture
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture10[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("test_npc_multi", "Test NPC Multi")
	## (await removed — --quit ends after frame 1; signals fire synchronously)

	var lines10: Array = _signal_capture[1]
	if lines10.size() > 0 and lines10[0] == "Multi-speaker idle line.":
		_pass("T10: trigger evaluation correct — multi-speaker state skipped when met_pig==true, idle_flavor returned")
	else:
		_fail("T10: expected idle_flavor 'Multi-speaker idle line.' but got: " + str(lines10))

	## -----------------------------------------------------------------------
	## Test 11: on_dismiss fires correctly after multi-speaker state
	## -----------------------------------------------------------------------
	state_node.data["chapter1"]["met_pig"] = false
	runner._on_dialogue_requested("test_npc_multi", "Test NPC Multi")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	sigs.dialogue_dismissed.emit()
	if state_node.data["chapter1"]["met_pig"] == true:
		_pass("T11: on_dismiss fires and mutates state after multi-speaker sequence")
	else:
		_fail("T11: on_dismiss did not mutate state after multi-speaker sequence")

	## -----------------------------------------------------------------------
	## Test 12: backward compat — string-only state works identically
	## -----------------------------------------------------------------------
	## Re-inject original fixture and run T4 scenario again to confirm no regression.
	runner._catalogue["test_npc"] = fixture
	state_node.data["chapter1"]["met_pig"] = false
	state_node.data["chapter1"]["met_murrow"] = false
	state_node.data["chapter1"]["has_law_binder"] = false
	var capture12 := _signal_capture
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture12[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("test_npc", "Test NPC")
	## (await removed — --quit ends after frame 1; signals fire synchronously)

	var lines12: Array = _signal_capture[1]
	if lines12.size() > 0 and lines12[0] is String and lines12[0] == "Pig has not been met.":
		_pass("T12: backward compat — string-only state behaves identically after multi-speaker extension")
	else:
		_fail("T12: backward compat broken; got: " + str(lines12))

	## -----------------------------------------------------------------------
	## T13–T16: Chapter 1 Phase A.2 — award_badge / unlock_route action types.
	## Inject a synthetic dialogue with on_dismiss containing the new actions
	## and verify state mutation + signal emission. Also assert that unknown
	## badge/route ids log a warning but do not crash.
	## -----------------------------------------------------------------------
	var phase_a_fixture: Dictionary = {
		"version": 1,
		"npc_id": "test_npc_phase_a",
		"states": [
			{
				"id": "award_and_unlock",
				"trigger": "chapter1.met_pig == false",
				"line": "Chapter close.",
				"on_dismiss": [
					{ "set": "chapter1.complete", "value": true },
					{ "award_badge": "day_one_survivor" },
					{ "unlock_route": "residential" },
					{ "unlock_route": "business_district" },
					{ "unlock_route": "court_plaza" }
				]
			},
			{
				"id": "unknown_ids",
				"trigger": "chapter1.met_pig == true",
				"line": "Unknown ids.",
				"on_dismiss": [
					{ "award_badge": "nonexistent_badge_xyz" },
					{ "unlock_route": "nonexistent_route_xyz" }
				]
			}
		],
		"idle_flavor": []
	}
	runner._catalogue["test_npc_phase_a"] = phase_a_fixture

	## Ensure schema preconditions: badges + routes_unlocked dicts exist
	## with the declared keys (state.gd reset_state should provide them).
	if not state_node.data.has("badges"):
		state_node.data["badges"] = {"day_one_survivor": false}
	if not state_node.data.has("routes_unlocked"):
		state_node.data["routes_unlocked"] = {
			"residential": false,
			"business_district": false,
			"court_plaza": false,
		}
	## Reset to baseline before each subtest.
	state_node.data["badges"]["day_one_survivor"] = false
	state_node.data["routes_unlocked"]["residential"] = false
	state_node.data["routes_unlocked"]["business_district"] = false
	state_node.data["routes_unlocked"]["court_plaza"] = false
	if state_node.data["chapter1"].has("complete"):
		state_node.data["chapter1"]["complete"] = false

	## Capture signal emissions.
	var badge_captures: Array = []
	var route_captures: Array = []
	var badge_signal_handler := func(badge_id: String) -> void: badge_captures.append(badge_id)
	var route_signal_handler := func(route_id: String) -> void: route_captures.append(route_id)
	if sigs.has_signal("badge_awarded"):
		sigs.badge_awarded.connect(badge_signal_handler)
	if sigs.has_signal("route_unlocked"):
		sigs.route_unlocked.connect(route_signal_handler)

	## Test 13 — award_badge writes State.data.badges + emits badge_awarded.
	state_node.data["chapter1"]["met_pig"] = false
	runner._on_dialogue_requested("test_npc_phase_a", "Phase A Test")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	sigs.dialogue_dismissed.emit()
	## (await removed — --quit ends after frame 1; signals fire synchronously)

	if state_node.data["badges"]["day_one_survivor"] == true \
			and badge_captures.size() == 1 \
			and badge_captures[0] == "day_one_survivor":
		_pass("T13: award_badge writes State.data.badges + emits badge_awarded")
	else:
		_fail("T13: award_badge failed; badges=%s signal_captures=%s" % [
			str(state_node.data["badges"]), str(badge_captures)
		])

	## Test 14 — unlock_route writes State.data.routes_unlocked + emits signal.
	if state_node.data["routes_unlocked"]["residential"] == true \
			and state_node.data["routes_unlocked"]["business_district"] == true \
			and state_node.data["routes_unlocked"]["court_plaza"] == true \
			and route_captures.size() == 3 \
			and route_captures[0] == "residential" \
			and route_captures[1] == "business_district" \
			and route_captures[2] == "court_plaza":
		_pass("T14: unlock_route writes State.data.routes_unlocked + emits route_unlocked (3 routes)")
	else:
		_fail("T14: unlock_route failed; routes=%s signal_captures=%s" % [
			str(state_node.data["routes_unlocked"]), str(route_captures)
		])

	## Test 15 — set + new actions can coexist in the same on_dismiss.
	if state_node.data["chapter1"]["complete"] == true:
		_pass("T15: set + award_badge + unlock_route coexist in one on_dismiss")
	else:
		_fail("T15: set action did not fire alongside new action types; complete=%s" % str(state_node.data["chapter1"]["complete"]))

	## Test 16 — unknown badge_id and route_id are rejected with a warning
	## (no crash; State unchanged).
	badge_captures.clear()
	route_captures.clear()
	state_node.data["chapter1"]["met_pig"] = true
	runner._on_dialogue_requested("test_npc_phase_a", "Phase A Test")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	sigs.dialogue_dismissed.emit()
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	## Unknown ids must NOT have been added to the dicts.
	var unknown_rejected: bool = (
		not state_node.data["badges"].has("nonexistent_badge_xyz")
		and not state_node.data["routes_unlocked"].has("nonexistent_route_xyz")
		and badge_captures.size() == 0
		and route_captures.size() == 0
	)
	if unknown_rejected:
		_pass("T16: unknown badge_id / route_id rejected (warning logged, no crash, no state mutation)")
	else:
		_fail("T16: unknown ids leaked through; badges=%s routes=%s badge_captures=%s route_captures=%s" % [
			str(state_node.data["badges"]), str(state_node.data["routes_unlocked"]),
			str(badge_captures), str(route_captures)
		])

	## -----------------------------------------------------------------------
	## T17–T19: Chapter 1 Phase A.3 — V1.A Asia hint dispatch.
	## Load the production asia_hint_states_ch1.json directly into the
	## runner under the "asia" key (mirroring _merge_asia_hint_states but
	## without depending on the merge with asia.json — testing the V1.A
	## states in isolation). Then set chapter1 flags to trigger specific
	## V1.A states and assert the canonical line is returned.
	## -----------------------------------------------------------------------
	const ASIA_V1A_PATH: String = "res://data/dialogues/asia_hint_states_ch1.json"
	var asia_file := FileAccess.open(ASIA_V1A_PATH, FileAccess.READ)
	if asia_file == null:
		_fail("T17: could not open " + ASIA_V1A_PATH)
		_finish()
		return
	var asia_parsed = JSON.parse_string(asia_file.get_as_text())
	asia_file.close()
	if asia_parsed == null:
		_fail("T17: asia_hint_states_ch1.json parse failed")
		_finish()
		return

	## Install V1.A states standalone under a fresh key (avoid colliding with
	## any asia.json that the runner may have auto-loaded during _ready).
	runner._catalogue["asia_v1a_isolated"] = asia_parsed

	## Helper: reset every chapter1 flag used by V1.A triggers to false.
	var v1a_flags: Array = [
		"pig_revealed_crisis", "met_murrow", "has_law_binder", "recruited_crab",
		"has_rights_memo", "recruited_whimsy", "halina_met",
		"archive_research_complete", "court_ready", "won_court",
		"received_swine_postcard",
	]
	var reset_flags := func() -> void:
		for flag in v1a_flags:
			state_node.data["chapter1"][flag] = false

	## Test 17 — first state (`!pig_revealed_crisis`) matches at chapter start.
	reset_flags.call()
	_signal_capture[1] = []
	var capture17 := _signal_capture
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture17[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("asia_v1a_isolated", "Asia")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	var lines17: Array = _signal_capture[1]
	var expected17: String = "You should talk to Mr. Pig first. He's the loudest crisis in the room."
	if lines17.size() > 0 and lines17[0] == expected17:
		_pass("T17: V1.A state 1 (`!pig_revealed_crisis`) dispatches canonical line")
	else:
		_fail("T17: expected '%s' but got: %s" % [expected17, str(lines17)])

	## Test 18 — state 7 (`recruited_whimsy && !halina_met`) — phase-8 new
	## state authored from V1.A pack §B.1.
	reset_flags.call()
	state_node.data["chapter1"]["pig_revealed_crisis"] = true
	state_node.data["chapter1"]["met_murrow"] = true
	state_node.data["chapter1"]["has_law_binder"] = true
	state_node.data["chapter1"]["recruited_crab"] = true
	state_node.data["chapter1"]["has_rights_memo"] = true
	state_node.data["chapter1"]["recruited_whimsy"] = true
	_signal_capture[1] = []
	var capture18 := _signal_capture
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture18[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("asia_v1a_isolated", "Asia")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	var lines18: Array = _signal_capture[1]
	var expected18: String = "Mrs. Sikorska is in the meeting room. She brought her own folder."
	if lines18.size() > 0 and lines18[0] == expected18:
		_pass("T18: V1.A state 7 (`recruited_whimsy && !halina_met`) dispatches canonical line")
	else:
		_fail("T18: expected '%s' but got: %s" % [expected18, str(lines18)])

	## Test 19 — state 12 default fallback (`received_swine_postcard`).
	reset_flags.call()
	for flag in v1a_flags:
		state_node.data["chapter1"][flag] = true
	## won_court isn't in state.gd default set; ensure it can be set for the test.
	## V1.A state 10 trigger uses `!won_court`, state 11 uses `won_court && !received_swine_postcard`.
	## Setting all to true means received_swine_postcard==true → state 12 matches.
	_signal_capture[1] = []
	var capture19 := _signal_capture
	sigs.dialogue_line_ready.connect(func(s: String, _npc_id: String, l: Array) -> void:
		capture19[1] = l
	, CONNECT_ONE_SHOT)
	runner._on_dialogue_requested("asia_v1a_isolated", "Asia")
	## (await removed — --quit ends after frame 1; signals fire synchronously)
	var lines19: Array = _signal_capture[1]
	var expected19: String = "For the first time today, nothing is actively on fire. I give it twelve minutes."
	if lines19.size() > 0 and lines19[0] == expected19:
		_pass("T19: V1.A state 12 (default; chapter coda) dispatches canonical line")
	else:
		_fail("T19: expected '%s' but got: %s" % [expected19, str(lines19)])

	_finish()


func _pass(msg: String) -> void:
	_pass_count += 1
	print("[TestDialogueRunner] PASS: ", msg)


func _fail(msg: String) -> void:
	_fail_count += 1
	printerr("[TestDialogueRunner] FAIL: ", msg)


func _finish() -> void:
	print("")
	print("[TestDialogueRunner] Results: %d passed, %d failed" % [_pass_count, _fail_count])
	if _fail_count > 0:
		quit(1)
	else:
		print("[TestDialogueRunner] PASS")
		quit(0)

